modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-api"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-mobile"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "healthcheck"

[[workflows.workflow]]
name = "typecheck-api"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run typecheck"

[[workflows.workflow]]
name = "typecheck-mobile"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/raimzeal-mobile run typecheck"

[[workflows.workflow]]
name = "typecheck-web"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/raimzeal run typecheck"

[[workflows.workflow]]
name = "healthcheck"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "curl -sf http://localhost:80/api/healthz && echo 'API healthy'"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0", "github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 5000

[[ports]]
localPort = 18577
externalPort = 3000

[[ports]]
localPort = 20059
externalPort = 3002

[[ports]]
localPort = 24798
externalPort = 3001

[[ports]]
localPort = 24799
externalPort = 4200

