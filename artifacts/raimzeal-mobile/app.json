{
  "expo": {
    "name": "RAIMZEAL",
    "slug": "raimzeal-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "raimzeal-mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.raimzeal.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow RAIMZEAL to access your photo library to save and view progress photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow RAIMZEAL to save progress photos to your photo library.",
        "NSLocationWhenInUseUsageDescription": "Allow RAIMZEAL to access your location to track outdoor workouts and activities.",
        "NSCameraUsageDescription": "Allow RAIMZEAL to access your camera to scan food barcodes.",
        "NSUserNotificationsUsageDescription": "Allow RAIMZEAL to send you workout reminders and motivational notifications."
      }
    },
    "android": {
      "package": "com.raimzeal.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#09090b"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow RAIMZEAL to access your camera to scan food barcodes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2E8B57",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RAIMZEAL to access your location to track outdoor workouts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyPolicyUrl": "https://www.raimzeal.com/privacy",
      "termsOfServiceUrl": "https://www.raimzeal.com/terms"
    }
  }
}
