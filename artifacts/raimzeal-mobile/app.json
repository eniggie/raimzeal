{
  "expo": {
    "name": "RAIMZEAL",
    "slug": "raimzeal",
    "owner": "econteur",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "raimzeal",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.replit.raimzeal",
      "buildNumber": "23",
      "associatedDomains": [
        "applinks:raimzeal.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow RAIMZEAL to access your photo library to save and view progress photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow RAIMZEAL to save progress photos to your photo library.",
        "NSLocationWhenInUseUsageDescription": "Allow RAIMZEAL to access your location to track outdoor workouts and activities.",
        "NSCameraUsageDescription": "Allow RAIMZEAL to access your camera to scan food barcodes.",
        "NSUserNotificationsUsageDescription": "Allow RAIMZEAL to send you workout reminders and motivational notifications."
      }
    },
    "android": {
      "package": "com.econteur.raimzeal",
      "versionCode": 25,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "raimzeal.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#09090b"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "targetSdkVersion": 35
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://raimzeal.com/"
        }
      ],
      "expo-apple-authentication",
      [
        "react-native-health",
        {
          "healthSharePermission": "RAIMZEAL reads your Apple Health data \u2014 steps, sleep, heart rate and weight \u2014 to keep your fitness stats accurate and up to date.",
          "healthUpdatePermission": "RAIMZEAL writes your workout and activity data back to Apple Health so all your apps stay in sync."
        }
      ],
      "react-native-health-connect",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow RAIMZEAL to access your camera to scan food barcodes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2E8B57",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow RAIMZEAL to access your location to track outdoor workouts.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyPolicyUrl": "https://www.raimzeal.com/privacy",
      "termsOfServiceUrl": "https://www.raimzeal.com/terms",
      "googleWebClientId": "398551642-v5fe375j2mtj3ikesksn80iofsbvog1t.apps.googleusercontent.com",
      "googleIosClientId": "398551642-rgcdpv3f18hht5ls7jpo2v3djf9h7dei.apps.googleusercontent.com",
      "eas": {
        "projectId": "352f4ec9-8d51-4d18-8c68-97a1b3be0387"
      }
    }
  }
}